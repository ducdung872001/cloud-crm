{
  "name": "mentorhub-backend-stubs",
  "version": "0.1.0",
  "private": true,
  "description": "BE stubs cho MentorHub — Node + Express + Zod + mock data. Đủ để FE dev độc lập và là bộ khung cho BE team port sang NestJS/Spring production.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --loader tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --test --loader tsx src/**/*.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
