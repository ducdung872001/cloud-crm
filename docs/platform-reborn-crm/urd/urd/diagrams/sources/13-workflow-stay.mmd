%%{init: {'theme':'base', 'themeVariables': {'fontFamily':'Calibri'}}}%%
flowchart TB
    START([Khách liên hệ đặt phòng]) --> B1[Mở lịch phòng]
    B1 --> B2{Loại phòng\nkhách muốn?}
    B2 --> B3[Chọn ngày check-in/out]
    B3 --> B4{Phòng còn trống\ntrong khoảng đó?}
    B4 -->|Không| B5[Đề xuất phòng/ngày khác]
    B5 --> B2
    B4 -->|Có| B6[Tạo booking\n+ thông tin khách]
    B6 --> B7{Thu cọc?}
    B7 -->|Có| B8[Tạo phiếu thu cọc]
    B7 -->|Không| B9[Booking trạng thái\nĐã xác nhận]
    B8 --> B9

    B9 --> WAIT[Chờ khách đến]
    WAIT --> CI[Khách đến check-in]
    CI --> CI1[Nhân viên xác minh\n+ upload CMND]
    CI1 --> CI2{CMND đầy đủ?}
    CI2 -->|Không| CI1
    CI2 -->|Có| CI3[Ghi giờ nhận thực tế\n+ giao chìa khóa]
    CI3 --> CI4[Phòng → Có khách]

    CI4 --> STAY[Khách lưu trú]
    STAY --> EXTRA{Phát sinh\ndịch vụ kèm?}
    EXTRA -->|Có| EX1[Ghi nhận dịch vụ\nminibar/giặt là]
    EX1 --> STAY
    EXTRA -->|Không| CO[Khách trả phòng]

    CO --> CO1[Hệ thống tính:\n- Số đêm thực tế\n- Tiền phòng\n- DV phát sinh\n- Trừ cọc]
    CO1 --> CO2{Còn phải thu?}
    CO2 -->|Có| CO3[Thu phần còn lại]
    CO2 -->|Hoàn lại| CO4[Hoàn cọc thừa]
    CO3 --> CO5[Xác nhận check-out]
    CO4 --> CO5
    CO5 --> CO6[Phòng → Đang dọn]
    CO6 --> CO7[Housekeeping dọn]
    CO7 --> END([Phòng → Trống\nsẵn sàng đặt mới])

    classDef start fill:#10B981,stroke:#047857,color:#fff
    classDef action fill:#E1F5EE,stroke:#2C7A7B,color:#0F4C44
    classDef decision fill:#FEF3C7,stroke:#F59E0B,color:#78350F
    classDef state fill:#1F3A68,stroke:#1F3A68,color:#fff

    class START,END start
    class B1,B3,B5,B6,B8,CI1,CI3,EX1,CO1,CO3,CO4,CO5,CO7 action
    class B2,B4,B7,CI2,EXTRA,CO2 decision
    class B9,WAIT,CI,CI4,STAY,CO,CO6 state
