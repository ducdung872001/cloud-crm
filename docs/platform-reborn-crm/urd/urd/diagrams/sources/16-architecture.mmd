%%{init: {'theme':'base', 'themeVariables': {'fontFamily':'Calibri'}}}%%
flowchart TB
    subgraph CLIENT["💻 Client tier"]
        WEB[("React SPA<br/>Browser")]
        POS[("POS Terminal<br/>+ Máy in nhiệt<br/>+ Quét mã vạch<br/>+ Đầu đọc thẻ")]
    end

    subgraph EDGE["🛡️ Edge / CDN"]
        CDN[("CDN<br/>(static assets)")]
        WAF[("WAF<br/>+ Rate limit")]
    end

    subgraph APP["⚙️ Application tier"]
        LB[("Load Balancer")]
        API1[("API Server #1<br/>(stateless)")]
        API2[("API Server #2<br/>(stateless)")]
        API3[("API Server #N<br/>(stateless)")]
        WORKER[("Background<br/>Workers<br/>(jobs/cron)")]
    end

    subgraph DATA["💾 Data tier"]
        DB_M[("PostgreSQL<br/>Master")]
        DB_R[("Read Replicas")]
        REDIS[("Redis<br/>cache + queue")]
        S3[("S3 / Object<br/>Storage<br/>(files, ảnh)")]
    end

    subgraph EXT["🌐 External Services"]
        SSO_X[("SSO Reborn")]
        VAT_X[("E-invoice")]
        PAY_X[("Payment GW")]
        SMS_X[("SMS / Email<br/>/ Zalo / FB")]
        SHIP_X[("Shipping API")]
    end

    subgraph OBS["📊 Observability"]
        LOG[("ELK / Loki<br/>logs")]
        METRIC[("Prometheus<br/>+ Grafana")]
        ALERT[("Alertmanager<br/>→ Slack/Email")]
    end

    WEB --> CDN
    POS --> CDN
    CDN --> WAF
    WAF --> LB
    LB --> API1
    LB --> API2
    LB --> API3

    API1 --> DB_M
    API2 --> DB_R
    API3 --> DB_R
    API1 --> REDIS
    API2 --> REDIS
    API3 --> REDIS
    API1 --> S3

    WORKER --> DB_M
    WORKER --> REDIS
    WORKER --> SMS_X

    API1 <--> SSO_X
    API1 --> VAT_X
    API1 <--> PAY_X
    API1 --> SHIP_X

    API1 --> LOG
    API2 --> LOG
    API3 --> LOG
    API1 --> METRIC
    METRIC --> ALERT

    classDef client fill:#E1F5EE,stroke:#2C7A7B,color:#0F4C44
    classDef edge fill:#FEF3C7,stroke:#F59E0B,color:#78350F
    classDef app fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef data fill:#FAEEDA,stroke:#D97706,color:#7C2D12
    classDef ext fill:#E0E7FF,stroke:#6366F1,color:#3730A3
    classDef obs fill:#F3E8FF,stroke:#A855F7,color:#6B21A8

    class WEB,POS client
    class CDN,WAF edge
    class LB,API1,API2,API3,WORKER app
    class DB_M,DB_R,REDIS,S3 data
    class SSO_X,VAT_X,PAY_X,SMS_X,SHIP_X ext
    class LOG,METRIC,ALERT obs
