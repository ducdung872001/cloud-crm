{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Calibri, Arial, sans-serif",
    "fontSize": "18px",

    "primaryColor": "#1F3A68",
    "primaryTextColor": "#ffffff",
    "primaryBorderColor": "#1F3A68",
    "secondaryColor": "#2C7A7B",
    "secondaryTextColor": "#ffffff",
    "secondaryBorderColor": "#0F4C44",
    "tertiaryColor": "#F7F8FA",
    "tertiaryTextColor": "#2D3A4B",
    "tertiaryBorderColor": "#C8CDD3",

    "lineColor": "#2C7A7B",
    "textColor": "#2D3A4B",
    "mainBkg": "#1F3A68",
    "secondBkg": "#2C7A7B",
    "background": "#ffffff",

    "actorBkg": "#1F3A68",
    "actorBorder": "#1F3A68",
    "actorTextColor": "#ffffff",
    "actorLineColor": "#2C7A7B",

    "signalColor": "#2D3A4B",
    "signalTextColor": "#2D3A4B",
    "labelBoxBkgColor": "#E1F5EE",
    "labelBoxBorderColor": "#2C7A7B",
    "labelTextColor": "#0F4C44",
    "loopTextColor": "#2D3A4B",
    "activationBkgColor": "#E1F5EE",
    "activationBorderColor": "#2C7A7B",
    "sequenceNumberColor": "#ffffff",

    "noteBkgColor": "#FFF7E6",
    "noteBorderColor": "#F59E0B",
    "noteTextColor": "#78350F",

    "altBackground": "#F7F8FA",

    "stateBkg": "#1F3A68",
    "stateLabelColor": "#ffffff",
    "transitionColor": "#2D3A4B",
    "transitionLabelColor": "#2D3A4B",
    "compositeBackground": "#F7F8FA",
    "compositeBorder": "#C8CDD3",
    "compositeTitleBackground": "#1F3A68",
    "specialStateColor": "#7C3AED",
    "errorBkgColor": "#FEE2E2",
    "errorTextColor": "#991B1B",

    "edgeLabelBackground": "#ffffff",
    "clusterBkg": "#F7F8FA",
    "clusterBorder": "#C8CDD3",
    "titleColor": "#1F3A68",

    "nodeBorder": "#1F3A68",
    "nodeTextColor": "#ffffff"
  },
  "flowchart": {
    "nodeSpacing": 50,
    "rankSpacing": 60,
    "padding": 15,
    "useMaxWidth": false
  },
  "sequence": {
    "actorMargin": 60,
    "messageMargin": 40,
    "boxMargin": 10,
    "noteMargin": 10,
    "useMaxWidth": false,
    "diagramMarginX": 50,
    "diagramMarginY": 20
  },
  "stateDiagram": {
    "useMaxWidth": false,
    "padding": 15
  },
  "er": {
    "useMaxWidth": false,
    "entityPadding": 15,
    "fontSize": 16
  }
}
