%%{init: {'theme':'base','themeVariables':{'fontFamily':'Calibri','fontSize':'18px'}}}%%
sequenceDiagram
    autonumber
    actor REC as 👤 Receptionist
    participant POS as POS Page
    participant CS as CustomerService
    participant SS as SalesService
    participant FS as FinanceService
    participant WS as WarehouseService
    participant CRS as CareService
    participant DB as Database

    REC->>POS: Mở POS, scan mã hoặc chọn SP
    POS->>POS: Update giỏ local state
    REC->>POS: Search khách "Nguyễn"
    POS->>CS: GET /customer/filter?keyword=Nguyễn
    CS-->>POS: Danh sách khách
    REC->>POS: Chọn khách
    REC->>POS: Bấm Thanh toán
    POS->>SS: POST /sales/invoice/create<br/>{ items, customer, payment }
    activate SS
    SS->>DB: BEGIN transaction
    SS->>DB: INSERT invoice
    SS->>DB: INSERT invoice_item × N
    SS->>WS: Trừ tồn kho cho từng SP
    WS->>DB: UPDATE warehouse_stock
    WS->>DB: INSERT stock_issue
    WS-->>SS: OK
    SS->>FS: Sinh phiếu thu
    FS->>DB: INSERT cashbook
    FS-->>SS: OK
    SS->>CRS: Cộng điểm tích lũy
    CRS->>DB: UPDATE loyalty_wallet
    CRS-->>SS: OK
    SS->>DB: COMMIT
    SS-->>POS: { invoiceId, code }
    deactivate SS
    POS->>POS: Show ReceiptModal
    REC->>POS: Bấm In hóa đơn
    POS->>POS: Trigger window.print()
