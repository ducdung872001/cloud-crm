%%{init: {'theme':'base','themeVariables':{'fontFamily':'Calibri','fontSize':'18px'}}}%%
flowchart TB
    INET((Internet Users))

    subgraph EDGE["Edge tier"]
      CDN[CloudFlare CDN]
      WAF[WAF + DDoS]
      LB[Cloud LB<br/>2× HA]
    end

    subgraph K8S["Kubernetes Cluster"]
      direction TB
      ING[Ingress nginx]
      subgraph FE_DEPLOY["Frontend Deploy (3 pods, HPA)"]
        FE1[FE pod]
        FE2[FE pod]
        FE3[FE pod]
      end
      subgraph BE_DEPLOY["Backend Deploys (per service, HPA)"]
        BE_AUTH[Auth pods × N]
        BE_SALES[Sales pods × N]
        BE_FIN[Finance pods × N]
        BE_OTHER[... other services]
      end
      WORKER[Background Workers]
      CRON[Cron Jobs]
    end

    subgraph DATA["Data tier"]
      PG_M[(PG Master)]
      PG_R[(PG Replicas)]
      REDIS[(Redis Cluster)]
      S3[(Object Storage)]
    end

    subgraph OBS["Observability"]
      PROM[Prometheus]
      GRAF[Grafana]
      LOKI[Loki / ELK]
      ALERT[Alertmanager]
    end

    subgraph CICD["CI/CD"]
      GIT[Git Repo]
      CI[GitHub Actions /<br/>GitLab CI]
      REG[Docker Registry]
      ARGO[ArgoCD]
    end

    INET --> CDN
    CDN --> WAF
    WAF --> LB
    LB --> ING
    ING --> FE1
    ING --> FE2
    ING --> FE3
    ING --> BE_AUTH
    ING --> BE_SALES
    ING --> BE_FIN
    ING --> BE_OTHER
    BE_SALES --> PG_M
    BE_SALES --> PG_R
    BE_SALES --> REDIS
    BE_SALES --> S3
    WORKER --> REDIS
    WORKER --> PG_M
    CRON -.trigger.-> WORKER
    K8S -.metrics.-> PROM
    K8S -.logs.-> LOKI
    PROM --> GRAF
    LOKI --> GRAF
    PROM --> ALERT

    GIT --> CI
    CI --> REG
    CI --> ARGO
    ARGO -.deploy.-> K8S

    classDef edge fill:#E1F5EE,stroke:#2C7A7B,color:#0F4C44
    classDef k8s fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef data fill:#FAEEDA,stroke:#D97706,color:#7C2D12
    classDef obs fill:#7C3AED,stroke:#5B21B6,color:#fff
    classDef cicd fill:#D97706,stroke:#7C2D12,color:#fff

    class CDN,WAF,LB edge
    class ING,FE1,FE2,FE3,BE_AUTH,BE_SALES,BE_FIN,BE_OTHER,WORKER,CRON k8s
    class PG_M,PG_R,REDIS,S3 data
    class PROM,GRAF,LOKI,ALERT obs
    class GIT,CI,REG,ARGO cicd
