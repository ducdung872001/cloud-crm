%%{init: {'theme':'base','themeVariables':{'fontFamily':'Calibri','fontSize':'18px'}}}%%
sequenceDiagram
    autonumber
    actor CASH as 👤 Cashier
    participant POS as POS Page
    participant INV as InventoryService<br/>(stock + warehouse ops)
    participant CS as CustomerService
    participant SS as SalesService<br/>(order + invoice)
    participant MKT as MarketService<br/>(loyalty)
    participant CRS as CareService
    participant BS as BillingService
    participant DB as Database
    participant PR as Máy in bill

    CASH->>POS: Mở POS / scan barcode
    POS->>INV: GET /bizapi/inventory/product/search<br/>?keyword=barcode
    INV->>DB: SELECT product + stock
    INV-->>POS: { product, price, stock }
    POS->>POS: Add vào giỏ (local state)
    CASH->>POS: Search khách "SĐT 0909..."
    POS->>CS: GET /bizapi/care/customer/filter
    POS->>MKT: GET /bizapi/market/loyalty/wallet
    CS-->>POS: Danh sách khách
    MKT-->>POS: Điểm loyalty
    CASH->>POS: Chọn khách + phương thức TT
    CASH->>POS: Bấm Thanh toán
    POS->>SS: POST /bizapi/sales/order/create<br/>{ items, customer, payment }
    activate SS
    SS->>DB: BEGIN transaction
    SS->>DB: INSERT sales_order
    SS->>DB: INSERT order_item × N
    SS->>INV: Lock + trừ tồn SKU + ghi phiếu xuất
    INV->>DB: UPDATE inventory_stock<br/>(pessimistic lock)
    INV->>DB: INSERT stock_issue (warehouse op)
    INV-->>SS: OK
    SS->>BS: emit sales.invoice.paid event
    BS->>DB: INSERT cashbook (billing DB)
    Note over BS: cashbook thuộc billing — sales emit event, billing consume
    SS->>MKT: Cộng điểm loyalty
    MKT->>DB: UPDATE loyalty_wallet
    MKT-->>SS: OK
    SS->>DB: COMMIT
    SS-->>POS: { orderId, code, total }
    deactivate SS
    POS->>PR: Trigger print bill
    opt Khách yêu cầu VAT
      CASH->>POS: Bấm Xuất hóa đơn VAT
      POS->>BS: POST /bizapi/billing/einvoice/issue
      BS-->>POS: { invoiceNo, lookupUrl }
    end
    POS->>CASH: Hoàn tất giao dịch
