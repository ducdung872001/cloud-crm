%%{init: {'theme':'base','themeVariables':{'fontFamily':'Calibri','fontSize':'18px'}}}%%
flowchart LR
    subgraph CLIENT["Client Runtime"]
      POSTERM[POS Terminal<br/>Browser SPA]
      MOBILE[Mobile Web<br/>nhân viên kho]
      ADMIN[Admin Browser]
    end

    subgraph SYNC["Synchronous Request Flow"]
      direction TB
      REQ[HTTP Request] --> GW1[API Gateway]
      GW1 --> SVC1[Microservice handler]
      SVC1 --> DB1[(DB transaction)]
      DB1 --> RESP[HTTP Response]
    end

    subgraph ASYNC["Async Background Processes"]
      direction TB
      MQ[(Message Queue<br/>RabbitMQ/Kafka)]
      SYNC_JOB[Marketplace Sync Job<br/>Shopee/Lazada/Tiki]
      WEBHOOK[Webhook Dispatcher<br/>order.created event]
      STOCK_JOB[Stock recon job<br/>nightly]
      BATCH[Batch Report Job<br/>daily sales summary]
      LOYALTY[Loyalty points<br/>accrual worker]
    end

    subgraph SCHED["Scheduled Jobs (cron)"]
      direction TB
      C1[00:00 đối soát tồn kho]
      C2[02:00 tổng hợp doanh thu]
      C3[06:00 pull đơn sàn]
      C4[Mỗi 5 phút<br/>push stock lên sàn]
      C5[Mỗi giờ<br/>retry webhook DLQ]
    end

    POSTERM --> REQ
    MOBILE --> REQ
    ADMIN --> REQ

    SVC1 -.publish event.-> MQ
    MQ --> SYNC_JOB
    MQ --> WEBHOOK
    MQ --> LOYALTY

    C1 --> STOCK_JOB
    C2 --> BATCH
    C3 --> SYNC_JOB
    C4 --> SYNC_JOB
    C5 --> WEBHOOK

    classDef client fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef sync fill:#2C7A7B,stroke:#0F4C44,color:#fff
    classDef async fill:#7C3AED,stroke:#5B21B6,color:#fff
    classDef sched fill:#D97706,stroke:#7C2D12,color:#fff

    class POSTERM,MOBILE,ADMIN client
    class REQ,GW1,SVC1,DB1,RESP sync
    class MQ,SYNC_JOB,WEBHOOK,STOCK_JOB,BATCH,LOYALTY async
    class C1,C2,C3,C4,C5 sched
