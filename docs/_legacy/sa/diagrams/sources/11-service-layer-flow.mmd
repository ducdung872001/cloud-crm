flowchart TB
    PAGE["Page Component<br/>(e.g. POS create_sale_add)"]
    HOOK["useEffect / event handler<br/>onClickAddToCart"]
    SVC["Service class<br/>InventoryService.searchProduct()"]
    URLS["urlsApi.inventory.search<br/>= /bizapi/inventory/product/search"]
    HELPER["apiHelper<br/>(apiGet / apiPost)"]
    FETCH["fetch(url, config)"]
    INT_REQ["fetch-intercept REQUEST<br/>+ Authorization Bearer<br/>+ X-Tenant-Id<br/>+ X-Selected-Role<br/>+ URL rewrite"]
    NET[("HTTPS")]
    GW["API Gateway"]
    BE["Inventory Microservice"]
    DB[("inventory_db")]
    INT_RES["fetch-intercept RESPONSE<br/>+ check 401 → refresh/logout<br/>+ unwrap { data }"]
    STATE["setState(products)"]
    RENDER["Re-render ProductCard list"]

    PAGE --> HOOK
    HOOK --> SVC
    SVC --> URLS
    SVC --> HELPER
    HELPER --> FETCH
    FETCH --> INT_REQ
    INT_REQ --> NET
    NET --> GW
    GW --> BE
    BE --> DB
    DB --> BE
    BE --> GW
    GW --> NET
    NET --> INT_RES
    INT_RES --> HELPER
    HELPER --> SVC
    SVC --> STATE
    STATE --> RENDER

    classDef fe fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef http fill:#D97706,stroke:#7C2D12,color:#fff
    classDef be fill:#2C7A7B,stroke:#0F4C44,color:#fff
    classDef data fill:#FAEEDA,stroke:#D97706,color:#7C2D12

    class PAGE,HOOK,SVC,URLS,HELPER,FETCH,STATE,RENDER fe
    class INT_REQ,INT_RES,NET,GW http
    class BE be
    class DB data
