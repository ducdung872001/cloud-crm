%%{init: {'theme':'base', 'themeVariables': {'fontFamily':'Calibri'}}}%%
flowchart TB
    subgraph CLIENT["💻 Client tier"]
        POS[("POS Terminal<br/>+ Máy in nhiệt<br/>+ Scanner barcode")]
        WEB[("React SPA<br/>Browser")]
        MOB[("Mobile<br/>Warehouse scanner")]
    end

    subgraph EDGE["🛡️ Edge"]
        CDN[("CDN<br/>static assets")]
        WAF[("WAF<br/>+ Rate limit")]
        GW[("API Gateway<br/>URL prefix routing")]
    end

    subgraph APP["⚙️ Microservices (stateless)"]
        SALES_S[("Sales / POS")]
        INV_S[("Inventory")]
        WH_S[("Warehouse")]
        FIN_S[("Finance")]
        PUR_S[("Purchase")]
        LOG_S[("Logistics")]
        CARE_S[("Customer Care")]
        BILL_S[("Billing / VAT")]
        MKT_S[("Marketing")]
        NOTIF_S[("Notification")]
        AUTH_S[("Auth / IAM")]
        BPM_S[("BPM / Workflow")]
        WORKER[("Workers<br/>jobs + cron")]
    end

    subgraph DATA["💾 Data tier"]
        DB_M[("PostgreSQL<br/>Master")]
        DB_R[("Read Replicas")]
        REDIS[("Redis<br/>cache + queue")]
        S3[("S3 Object<br/>Storage")]
        ES[("Elasticsearch<br/>search + logs")]
    end

    subgraph EXT["🌐 External Services"]
        SSO_X[("SSO Reborn")]
        VAT_X[("VNPT/MISA<br/>E-invoice")]
        PAY_X[("VNPay/MoMo<br/>ZaloPay")]
        SHIP_X[("GHN/GHTK<br/>J&T/VNPost")]
        MKP_X[("Shopee/Lazada<br/>TikTok Shop")]
        COMM_X[("SMS/Email<br/>Zalo/FB")]
    end

    subgraph OBS["📊 Observability"]
        LOG[("Loki<br/>logs")]
        METRIC[("Prometheus<br/>+ Grafana")]
        ALERT[("Alertmanager")]
    end

    POS --> CDN
    WEB --> CDN
    MOB --> CDN
    CDN --> WAF
    WAF --> GW

    GW --> SALES_S
    GW --> INV_S
    GW --> WH_S
    GW --> FIN_S
    GW --> PUR_S
    GW --> LOG_S
    GW --> CARE_S
    GW --> BILL_S
    GW --> MKT_S
    GW --> NOTIF_S
    GW --> AUTH_S
    GW --> BPM_S

    SALES_S --> DB_M
    INV_S --> DB_M
    WH_S --> DB_M
    FIN_S --> DB_M
    PUR_S --> DB_M
    CARE_S --> DB_R
    MKT_S --> DB_R
    AUTH_S --> DB_R

    SALES_S --> REDIS
    INV_S --> REDIS
    NOTIF_S --> REDIS
    SALES_S --> ES
    CARE_S --> ES
    WH_S --> S3
    BILL_S --> S3

    WORKER --> DB_M
    WORKER --> REDIS
    WORKER --> NOTIF_S

    AUTH_S <--> SSO_X
    BILL_S --> VAT_X
    SALES_S <--> PAY_X
    LOG_S <--> SHIP_X
    SALES_S <--> MKP_X
    NOTIF_S --> COMM_X

    SALES_S --> LOG
    INV_S --> LOG
    FIN_S --> LOG
    LOG --> METRIC
    METRIC --> ALERT

    classDef client fill:#E1F5EE,stroke:#2C7A7B,color:#0F4C44
    classDef edge fill:#FEF3C7,stroke:#F59E0B,color:#78350F
    classDef app fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef data fill:#FAEEDA,stroke:#D97706,color:#7C2D12
    classDef ext fill:#E0E7FF,stroke:#6366F1,color:#3730A3
    classDef obs fill:#F3E8FF,stroke:#A855F7,color:#6B21A8

    class POS,WEB,MOB client
    class CDN,WAF,GW edge
    class SALES_S,INV_S,WH_S,FIN_S,PUR_S,LOG_S,CARE_S,BILL_S,MKT_S,NOTIF_S,AUTH_S,BPM_S,WORKER app
    class DB_M,DB_R,REDIS,S3,ES data
    class SSO_X,VAT_X,PAY_X,SHIP_X,MKP_X,COMM_X ext
    class LOG,METRIC,ALERT obs
