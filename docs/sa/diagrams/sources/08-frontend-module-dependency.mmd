%%{init: {'theme':'base','themeVariables':{'fontFamily':'Calibri','fontSize':'18px'}}}%%
flowchart TB
    subgraph FE["Frontend Layered Architecture"]
      direction TB
      PAGES["📄 Pages (167)<br/>UI + business logic"]
      COMP["🎨 Components (78)<br/>Reusable UI"]
      HOOKS["🪝 Hooks (~30)<br/>Logic encapsulation"]
      CTX["🌐 Contexts (5)<br/>Global state"]
      SVC["📡 Services (240)<br/>API layer"]
      AH["🔧 apiHelper<br/>Fetch wrapper"]
      INT["⚙️ fetch-intercept<br/>Auth + URL rewrite"]
      FETCH["🌐 fetch / Browser HTTP"]
    end

    PAGES --> COMP
    PAGES --> HOOKS
    PAGES --> CTX
    PAGES --> SVC
    HOOKS --> SVC
    HOOKS --> CTX
    COMP --> HOOKS
    SVC --> AH
    AH --> FETCH
    INT --> FETCH

    BACKEND[("☁️ Backend Microservices")]
    FETCH --> INT
    INT --> BACKEND

    classDef ui fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef logic fill:#2C7A7B,stroke:#0F4C44,color:#fff
    classDef data fill:#7C3AED,stroke:#5B21B6,color:#fff
    classDef http fill:#D97706,stroke:#7C2D12,color:#fff
    classDef ext fill:#FEF3C7,stroke:#F59E0B,color:#78350F

    class PAGES,COMP ui
    class HOOKS,CTX logic
    class SVC,AH data
    class INT,FETCH http
    class BACKEND ext
