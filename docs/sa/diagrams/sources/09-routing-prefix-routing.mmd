flowchart LR
    BR((Browser))
    subgraph FE["Frontend SPA"]
      ROUTES["routes.tsx<br/>167 routes"]
      INTERCEPT["fetchConfig.ts<br/>URL rewrite"]
    end
    subgraph BE["Backend Services"]
      MAIN["Main API<br/>/api"]
      AUTH["Auth Service<br/>/authenticator"]
      SALES["Sales<br/>/bizapi/sales"]
      FIN["Finance<br/>/bizapi/finance"]
      INV["Inventory<br/>/bizapi/inventory"]
      WH["Warehouse<br/>/bizapi/warehouse"]
      CARE["Care<br/>/bizapi/care"]
      BILLING["Billing<br/>/bizapi/billing"]
      LOG["Logistics<br/>/bizapi/logistics"]
      INTEG["Integration<br/>/bizapi/integration"]
      MKT["Market<br/>/bizapi/market"]
      NOTIF["Notification<br/>/bizapi/notification"]
      BPM["BPM Engine<br/>/bpmapi (external)"]
      CS["Customer Service<br/>/cs"]
      HR["HR<br/>/hr"]
    end

    BR --> ROUTES
    ROUTES --> INTERCEPT
    INTERCEPT -->|/api/*| MAIN
    INTERCEPT -->|/authenticator/*| AUTH
    INTERCEPT -->|/bizapi/sales/*| SALES
    INTERCEPT -->|/bizapi/finance/*| FIN
    INTERCEPT -->|/bizapi/inventory/*| INV
    INTERCEPT -->|/bizapi/warehouse/*| WH
    INTERCEPT -->|/bizapi/care/*| CARE
    INTERCEPT -->|/bizapi/billing/*| BILLING
    INTERCEPT -->|/bizapi/logistics/*| LOG
    INTERCEPT -->|/bizapi/integration/*| INTEG
    INTERCEPT -->|/bizapi/market/*| MKT
    INTERCEPT -->|/bizapi/notification/*| NOTIF
    INTERCEPT -->|/bpmapi/*| BPM
    INTERCEPT -->|/cs/*| CS
    INTERCEPT -->|/hr/*| HR

    classDef fe fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef be fill:#2C7A7B,stroke:#0F4C44,color:#fff
    classDef ext fill:#FEF3C7,stroke:#F59E0B,color:#78350F

    class ROUTES,INTERCEPT fe
    class MAIN,AUTH,SALES,FIN,INV,WH,CARE,BILLING,LOG,INTEG,MKT,NOTIF,CS,HR be
    class BR,BPM ext
