%%{init: {'theme':'base','themeVariables':{'fontFamily':'Calibri','fontSize':'18px'}}}%%
flowchart TB
    subgraph RETAIL["REBORN RETAIL CRM"]
      direction TB
      subgraph FE_MOD["Frontend SPA Modules"]
        POS_UI[POS / Bán hàng tại quầy]
        INV_UI[Inventory / Kho hàng]
        CUST_UI[Customer / Khách hàng]
        SALE_UI[Sales / Đơn hàng]
        FIN_UI[Finance / Tài chính]
        MKT_UI[Marketing / CSKH]
        RPT_UI[Reporting / Báo cáo]
        SET_UI[Settings / Cấu hình]
      end
      subgraph BE_CORE["Core Bounded Contexts"]
        SALES[sales<br/>POS, order, shift,<br/>invoice lifecycle]
        INVENTORY[inventory<br/>Tồn kho + warehouse +<br/>purchase order + NCC]
      end
      subgraph BE_OPS["Operational Contexts"]
        LOGISTICS[logistics<br/>Vận chuyển, COD]
        CARE[care<br/>Ticket, warranty, feedback]
        BILLING[billing<br/>Cashbook, debt, fund,<br/>payment, VAT TT78]
        INTEG[integration<br/>3rd party connectors]
      end
      subgraph BE_PLAT["Platform Contexts"]
        MARKET[market<br/>Campaign, voucher, loyalty]
        NOTIF[notification<br/>SMS/Email/Zalo/FB]
        AUTH[/authenticator<br/>SSO / RBAC]
        BPM[/bpmapi<br/>BPM Workflow]
      end
    end

    POS_UI --> SALES
    POS_UI --> INVENTORY
    POS_UI --> CUST_UI
    INV_UI --> INVENTORY
    SALE_UI --> SALES
    CUST_UI --> CARE
    CUST_UI --> MARKET
    FIN_UI --> BILLING
    MKT_UI --> MARKET
    RPT_UI --> SALES
    RPT_UI --> INVENTORY
    SET_UI --> AUTH

    SALES --> INVENTORY
    SALES --> BILLING
    SALES --> CARE
    SALES --> MARKET
    LOGISTICS --> SALES
    INTEG --> INVENTORY
    INTEG --> SALES
    MARKET --> SALES
    MARKET --> INVENTORY
    NOTIF --> CARE
    BPM --> SALES

    classDef feMod fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef core fill:#2C7A7B,stroke:#0F4C44,color:#fff
    classDef ops fill:#7C3AED,stroke:#5B21B6,color:#fff
    classDef plat fill:#D97706,stroke:#7C2D12,color:#fff

    class POS_UI,INV_UI,CUST_UI,SALE_UI,FIN_UI,MKT_UI,RPT_UI,SET_UI feMod
    class SALES,INVENTORY core
    class LOGISTICS,CARE,BILLING,INTEG ops
    class MARKET,NOTIF,AUTH,BPM plat
