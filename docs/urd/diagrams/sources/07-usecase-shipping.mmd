%%{init: {'theme':'base', 'themeVariables': {'fontFamily':'Calibri'}}}%%
flowchart LR
    SALES(("👤<br/>Sales Rep"))
    WH(("👤<br/>Warehouse<br/>Staff"))
    CUST(("👤<br/>Customer"))
    ADMIN(("👤<br/>Tenant<br/>Admin"))
    SHIP(("🌐<br/>Carrier API<br/>GHN/GHTK/J&T"))

    subgraph SYSTEM["Phân hệ Vận chuyển"]
        UC1((Cấu hình<br/>partner/API key))
        UC2((Tạo phiếu<br/>giao hàng))
        UC3((Tính phí<br/>vận chuyển))
        UC4((In label<br/>A4/A6))
        UC5((Bàn giao<br/>cho shipper))
        UC6((Tracking<br/>webhook))
        UC7((COD<br/>đối soát))
        UC8((Hoàn hàng<br/>return))
        UC9((Dashboard<br/>logistics))
        UC10((Tra cứu<br/>đơn vận))
    end

    ADMIN --> UC1
    SALES --> UC2
    SALES --> UC3
    WH --> UC4
    WH --> UC5
    WH --> UC7
    SALES --> UC9
    CUST --> UC10
    CUST --> UC6

    UC2 <-.create shipment.-> SHIP
    UC3 <-.quote API.-> SHIP
    UC6 <-.webhook.-> SHIP
    UC7 <-.reconcile.-> SHIP
    UC2 -.includes.-> UC3

    classDef actor fill:#1F3A68,stroke:#1F3A68,color:#fff
    classDef ext fill:#FEF3C7,stroke:#F59E0B,color:#78350F
    classDef uc fill:#E1F5EE,stroke:#2C7A7B,color:#0F4C44

    class SALES,WH,CUST,ADMIN actor
    class SHIP ext
    class UC1,UC2,UC3,UC4,UC5,UC6,UC7,UC8,UC9,UC10 uc
