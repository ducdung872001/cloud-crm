        EMAIL[("Email SMTP<br/>Gmail/SendGrid")]
        ZALO[("Zalo OA")]
        FB[("Facebook<br/>Messenger")]
    end

    CRM{{"<b>REBORN CRM</b><br/>(Cửa hàng & Spa)"}}

