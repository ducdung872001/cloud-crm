        UC3((Tạo nhanh<br/>thành viên))
        UC4((Xem hồ sơ<br/>chi tiết))
        UC5((Cập nhật<br/>thông tin))
        UC6((Import từ<br/>Excel))
        UC7((Export Excel<br/>/CSV))
        UC8((Định nghĩa<br/>trường tùy chỉnh))
        UC9((Cấu hình<br/>thẻ/nhóm/nguồn))
        UC10((Cấu hình<br/>cấu trúc xem))
    end

    STAFF --> UC1
    STAFF --> UC2
    STAFF --> UC4

    REC --> UC3

    MKT --> UC6
    MKT --> UC7

    ADMIN --> UC8
    ADMIN --> UC9
    ADMIN --> UC10
    ADMIN --> UC5

    UC3 -.extends.-> UC5
