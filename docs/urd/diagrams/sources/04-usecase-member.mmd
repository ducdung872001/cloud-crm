%%{init: {'theme':'base', 'themeVariables': {'fontFamily':'Calibri'}}}%%
flowchart LR
    STAFF(("👤<br/>Staff"))
    REC(("👤<br/>Receptionist"))
    MKT(("👤<br/>Marketer"))
    ADMIN(("👤<br/>Tenant<br/>Admin"))

    subgraph SYSTEM["Phân hệ Thành viên"]
