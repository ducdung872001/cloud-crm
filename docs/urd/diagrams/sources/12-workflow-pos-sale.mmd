%%{init: {'theme':'base', 'themeVariables': {'fontFamily':'Calibri'}}}%%
flowchart TB
    START([Đầu ca bán hàng]) --> A1[Cashier đăng nhập POS]
    A1 --> A2{Có ca<br/>đang mở?}
    A2 -->|Có| ON[Vào ca hiện tại]
    A2 -->|Không| A3[Chọn cấu hình ca]
    A3 --> A4[Nhập tiền đầu ca]
    A4 --> A5[Xác nhận vào ca]
    A5 --> ON

    ON --> W1[Quét barcode<br/>hoặc tìm SP]
    W1 --> W2{SP có trong<br/>kho cửa hàng?}
    W2 -->|Không| W3[Báo hết hàng<br/>đề xuất SP khác]
    W3 --> W1
    W2 -->|Có| W4[Thêm vào giỏ]
    W4 --> W5{Mua thêm?}
    W5 -->|Có| W1
    W5 -->|Không| W6[Chọn/Tạo khách hàng]

    W6 --> W7{Có KM/<br/>voucher?}
    W7 -->|Có| W8[Áp KM tự động<br/>+ nhập mã voucher]
    W7 -->|Không| W9
    W8 --> W9[Chốt giá + tính thuế]

    W9 --> P1{PT thanh toán?}
    P1 -->|Cash| P2[Nhận tiền mặt<br/>tính tiền thối]
    P1 -->|Card/QR| P3[Quét QR /<br/>cà thẻ → gateway]
    P1 -->|Chuyển khoản| P4[Xác nhận bank]
    P1 -->|Ghi nợ| P5[Check hạn mức<br/>+ ghi công nợ]
    P2 --> P6[In bill máy in nhiệt]
    P3 --> P6
    P4 --> P6
    P5 --> P6

    P6 --> V1{Khách cần<br/>VAT?}
    V1 -->|Có| V2[Nhập MST/tên<br/>→ phát hành HDDT]
    V1 -->|Không| V3
    V2 --> V3[Gửi bill qua email/Zalo]

    V3 --> NEXT{Tiếp tục<br/>bán?}
    NEXT -->|Có| W1
    NEXT -->|Không| END_DAY[Kết thúc ca]

    END_DAY --> C1[Đếm tiền thực tế]
    C1 --> C2[Kiểm kê tồn cuối ca]
    C2 --> C3[So sánh chênh lệch]
    C3 --> C4[Đóng ca + Báo cáo]
    C4 --> END([Đăng xuất])

    classDef start fill:#10B981,stroke:#047857,color:#fff
    classDef action fill:#E1F5EE,stroke:#2C7A7B,color:#0F4C44
    classDef decision fill:#FEF3C7,stroke:#F59E0B,color:#78350F
    classDef endNode fill:#1F3A68,stroke:#1F3A68,color:#fff

    class START,END start
    class A1,A3,A4,A5,W1,W3,W4,W6,W8,W9,P2,P3,P4,P5,P6,V2,V3,C1,C2,C3,C4 action
    class A2,W2,W5,W7,P1,V1,NEXT decision
    class ON,END_DAY endNode
