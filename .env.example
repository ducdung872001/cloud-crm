# CRM Banking – Environment Variables
# Copy to .env.local and fill in actual values

APP_ENV=development

# API Base URLs (no trailing slash)
APP_API_URL=http://localhost:8080
APP_ADMIN_URL=http://localhost:8080/adminapi
APP_BPM_URL=http://localhost:8081/bpmapi
APP_BIZ_URL=http://localhost:8082/bizapi
APP_AUTHENTICATOR_URL=http://localhost:8083/authenticator

# Domain (for SSO cookie scoping)
APP_DOMAIN=localhost
